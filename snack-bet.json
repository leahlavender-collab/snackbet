{
  "filename": "snack-bet.html",
  "language": "html",
  "description": "Snack Bet! - Weekly team time-picking tracker with JSONBin storage",
  "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Snack Bet! \ud83c\udf7f</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n    body { font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif; background: #F9FAFB; color: #111827; min-height: 100vh; padding: 28px 16px 60px; }\n    .wrap { max-width: 520px; margin: 0 auto; }\n    .header { text-align: center; margin-bottom: 22px; }\n    .header .icon { font-size: 38px; margin-bottom: 6px; }\n    .header h1 { font-size: 24px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 6px; }\n    .header p { color: #6B7280; font-size: 14px; }\n    .banner { border-radius: 12px; padding: 14px 16px; margin-bottom: 16px; text-align: center; border: 1.5px solid; }\n    .banner.green  { background: #F0FDF4; border-color: #86EFAC; color: #15803D; }\n    .banner.blue   { background: #EFF6FF; border-color: #BFDBFE; color: #1D4ED8; }\n    .banner.yellow { background: #FFFBEB; border-color: #FCD34D; color: #92400E; }\n    .banner.sky    { background: #F0F9FF; border-color: #BAE6FD; color: #0369A1; }\n    .banner .emoji { font-size: 20px; margin-bottom: 4px; }\n    .banner .title { font-size: 14px; font-weight: 600; margin-bottom: 3px; }\n    .banner .sub   { font-size: 13px; opacity: 0.85; }\n    .banner .count { font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }\n    .card { background: #fff; border: 1.5px solid #E5E7EB; border-radius: 14px; padding: 20px 16px; margin-bottom: 16px; }\n    .card.locked { opacity: 0.45; pointer-events: none; }\n    label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }\n    input[type=\"text\"] { width: 100%; font-size: 15px; padding: 10px 13px; border: 1.5px solid #D1D5DB; border-radius: 9px; outline: none; color: #111827; background: #FAFAFA; margin-bottom: 16px; }\n    input[type=\"text\"]:focus { border-color: #93C5FD; }\n    .slot-label { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 10px; }\n    .slot-label .hint { font-size: 12px; font-weight: 400; color: #9CA3AF; }\n    .slot-label .selected-tag { font-size: 12px; font-weight: 400; color: #2563EB; }\n    .grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 5px; }\n    .slot { border-radius: 6px; padding: 6px 2px; border: 1.5px solid #D1D5DB; background: #fff; cursor: pointer; font-size: 11px; font-weight: 600; color: #111827; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; text-align: center; line-height: 1; transition: background 0.1s, border-color 0.1s; }\n    .slot:hover:not(.taken):not(.sel) { background: #EFF6FF; border-color: #93C5FD; }\n    .slot.taken { background: #F3F4F6; border-color: #E5E7EB; color: #C4C9D4; cursor: not-allowed; }\n    .slot.sel   { background: #1D4ED8; border-color: #1D4ED8; color: #fff; }\n    .error { background: #FEF2F2; border: 1.5px solid #FCA5A5; border-radius: 9px; padding: 10px 14px; margin-bottom: 12px; color: #B91C1C; font-size: 14px; }\n    .success { background: #F0FDF4; border: 1.5px solid #86EFAC; border-radius: 9px; padding: 10px 14px; margin-bottom: 12px; color: #15803D; font-size: 14px; font-weight: 500; }\n    .hidden { display: none !important; }\n    .submit-btn { width: 100%; background: #111827; color: #fff; border: none; border-radius: 11px; padding: 14px 0; font-size: 15px; font-weight: 600; cursor: pointer; margin-bottom: 28px; letter-spacing: -0.2px; }\n    .submit-btn:disabled { background: #9CA3AF; cursor: not-allowed; }\n    .board-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }\n    .board-header h2 { font-size: 15px; font-weight: 700; }\n    .board-header .count-tag { font-size: 13px; font-weight: 400; color: #6B7280; margin-left: 6px; }\n    .refresh-btn { background: none; border: 1.5px solid #E5E7EB; border-radius: 7px; padding: 5px 11px; font-size: 12px; color: #6B7280; cursor: pointer; }\n    .refresh-btn:hover { border-color: #D1D5DB; }\n    .pick-list { display: flex; flex-direction: column; gap: 6px; }\n    .pick-row { display: flex; align-items: center; gap: 12px; background: #fff; border: 1.5px solid #E5E7EB; border-radius: 10px; padding: 10px 14px; }\n    .pick-num  { font-size: 11px; color: #D1D5DB; width: 18px; flex-shrink: 0; text-align: right; }\n    .pick-time { font-size: 14px; font-weight: 700; color: #1D4ED8; width: 78px; flex-shrink: 0; font-variant-numeric: tabular-nums; }\n    .pick-name { font-size: 14px; color: #374151; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .empty { text-align: center; padding: 36px 0; color: #9CA3AF; }\n    .empty .empty-icon { font-size: 32px; margin-bottom: 8px; }\n    .empty p { font-size: 14px; }\n  </style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"header\">\n    <div class=\"icon\">\ud83c\udf7f</div>\n    <h1>Snack Bet!</h1>\n    <p>1:30 PM \u2013 3:30 PM &nbsp;\u00b7&nbsp; No duplicates &nbsp;\u00b7&nbsp; Every Wednesday</p>\n  </div>\n\n  <!-- Status banners -->\n  <div id=\"banner-closed\" class=\"banner sky hidden\">\n    <div class=\"emoji\">\ud83d\udcc5</div>\n    <div class=\"title\" id=\"next-wed-label\"></div>\n    <div class=\"sub\">Betting opens at 12:00 PM Mountain Time</div>\n  </div>\n  <div id=\"banner-waiting\" class=\"banner yellow hidden\">\n    <div class=\"emoji\">\u23f3</div>\n    <div class=\"title\">Betting opens today at 12:00 PM MT</div>\n    <div class=\"count\" id=\"countdown-text\"></div>\n  </div>\n  <div id=\"banner-open\" class=\"banner green hidden\">\n    <div class=\"title\">\ud83d\udfe2 Betting is open! &nbsp;\u00b7&nbsp; <span id=\"slots-left\"></span></div>\n  </div>\n  <div id=\"banner-voted\" class=\"banner blue hidden\">\n    <div class=\"title\" id=\"voted-title\"></div>\n    <div class=\"sub\" id=\"voted-sub\"></div>\n  </div>\n\n  <!-- Betting form -->\n  <div class=\"card\" id=\"form-card\">\n    <label for=\"name-input\">Your name</label>\n    <input type=\"text\" id=\"name-input\" placeholder=\"Enter your name\" maxlength=\"40\" />\n    <div class=\"slot-label\">\n      <label style=\"margin:0\">Choose a time slot <span class=\"hint\">(all PM \u00b7 hover for name)</span></label>\n      <span class=\"selected-tag hidden\" id=\"selected-tag\"></span>\n    </div>\n    <div class=\"grid\" id=\"slot-grid\"></div>\n  </div>\n\n  <div id=\"error-msg\" class=\"error hidden\"></div>\n  <div id=\"success-msg\" class=\"success hidden\"></div>\n\n  <button class=\"submit-btn\" id=\"submit-btn\">Lock in my pick</button>\n\n  <!-- Picks board -->\n  <div class=\"board-header\">\n    <h2>Picks board <span class=\"count-tag\" id=\"board-count\"></span></h2>\n    <button class=\"refresh-btn\" onclick=\"loadPicks()\">\u21bb Refresh</button>\n  </div>\n  <div id=\"pick-list\" class=\"pick-list\">\n    <div class=\"empty\"><div class=\"empty-icon\">\ud83d\udd50</div><p>Loading picks\u2026</p></div>\n  </div>\n</div>\n\n<script>\n  // \u2500\u2500 CONFIG \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  const BIN_ID  = \"6a344924da38895dfed969d0\";\n  const API_KEY = \"$2a$10$OaYyTNpZSNUXK021PXPbsOglTOIuKb67TId4dAA8tWJFkE5cnoDS.\";\n  const TESTING_MODE = false; // set to true to disable Wednesday/noon restriction for testing\n  // \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n  const JSONBIN_URL = `https://api.jsonbin.io/v3/b/${BIN_ID}`;\n  const HEADERS = { \"Content-Type\": \"application/json\", \"X-Master-Key\": API_KEY };\n\n  // Generate slots: 1:30 PM \u2013 3:30 PM, every minute\n  const SLOTS = [];\n  for (let t = 13*60+30; t <= 15*60+30; t++) {\n    const h = Math.floor(t/60), m = t%60;\n    SLOTS.push(`${String(h).padStart(2,\"0\")}:${String(m).padStart(2,\"0\")}`);\n  }\n\n  function fmt(t) {\n    const [h,m] = t.split(\":\").map(Number);\n    return `${h%12||12}:${String(m).padStart(2,\"0\")} ${h<12?\"AM\":\"PM\"}`;\n  }\n  function fmtShort(t) {\n    const [h,m] = t.split(\":\").map(Number);\n    return `${h%12||12}:${String(m).padStart(2,\"0\")}`;\n  }\n\n  function getMtInfo() {\n    const parts = new Intl.DateTimeFormat(\"en-US\", {\n      timeZone: \"America/Denver\", weekday:\"long\", year:\"numeric\",\n      month:\"2-digit\", day:\"2-digit\", hour:\"2-digit\", minute:\"2-digit\", hour12:false\n    }).formatToParts(new Date());\n    const p = t => parts.find(x=>x.type===t)?.value??\"\";\n    return { weekday:p(\"weekday\"), year:p(\"year\"), month:p(\"month\"), day:p(\"day\"), hour:parseInt(p(\"hour\")), minute:parseInt(p(\"minute\")) };\n  }\n\n  function getWednesdayKey() {\n    const i = getMtInfo();\n    const base = new Date(`${i.year}-${i.month}-${i.day}T12:00:00Z`);\n    const back = (base.getUTCDay()-3+7)%7;\n    const wed = new Date(base.getTime()-back*86400000);\n    const wm = String(wed.getUTCMonth()+1).padStart(2,\"0\");\n    const wd = String(wed.getUTCDate()).padStart(2,\"0\");\n    return `${wed.getUTCFullYear()}-${wm}-${wd}`;\n  }\n\n  function getNextWednesdayLabel() {\n    const i = getMtInfo();\n    const base = new Date(`${i.year}-${i.month}-${i.day}T12:00:00Z`);\n    const ahead = ((3-base.getUTCDay()+7)%7)||7;\n    return new Intl.DateTimeFormat(\"en-US\",{weekday:\"long\",month:\"long\",day:\"numeric\"}).format(new Date(base.getTime()+ahead*86400000));\n  }\n\n  function getBettingStatus() {\n    if (TESTING_MODE) return \"open\";\n    const i = getMtInfo();\n    if (i.weekday===\"Wednesday\" && i.hour>=12) return \"open\";\n    if (i.weekday===\"Wednesday\") return \"waiting\";\n    return \"closed\";\n  }\n\n  // LocalStorage helpers for \"already voted\"\n  function getMyVote(weekKey) {\n    try { return JSON.parse(localStorage.getItem(`snackbet_${weekKey}`)); } catch { return null; }\n  }\n  function setMyVote(weekKey, vote) {\n    try { localStorage.setItem(`snackbet_${weekKey}`, JSON.stringify(vote)); } catch {}\n  }\n\n  // JSONBin\n  async function readPicks() {\n    const res = await fetch(`${JSONBIN_URL}/latest`, { headers: HEADERS });\n    if (!res.ok) { const t = await res.text().catch(()=>\"\"); throw new Error(`HTTP ${res.status}: ${t.slice(0,100)}`); }\n    const data = await res.json();\n    return data.record?.picks ?? [];\n  }\n  async function writePicks(picks) {\n    const res = await fetch(JSONBIN_URL, { method:\"PUT\", headers:HEADERS, body:JSON.stringify({picks}) });\n    if (!res.ok) { const t = await res.text().catch(()=>\"\"); throw new Error(`HTTP ${res.status}: ${t.slice(0,100)}`); }\n  }\n\n  // State\n  let picks = [];\n  let selected = null;\n  let myVote = null;\n  const weekKey = getWednesdayKey();\n\n  // UI helpers\n  const $ = id => document.getElementById(id);\n  function showError(msg) { $(\"error-msg\").textContent = msg; $(\"error-msg\").classList.remove(\"hidden\"); }\n  function hideError() { $(\"error-msg\").classList.add(\"hidden\"); }\n  function showSuccess(msg) { $(\"success-msg\").textContent = msg; $(\"success-msg\").classList.remove(\"hidden\"); setTimeout(()=>$(\"success-msg\").classList.add(\"hidden\"), 4500); }\n\n  function buildGrid() {\n    const grid = $(\"slot-grid\");\n    grid.innerHTML = \"\";\n    const takenMap = Object.fromEntries(picks.map(p=>[p.time, p.name]));\n    SLOTS.forEach(slot => {\n      const who = takenMap[slot];\n      const btn = document.createElement(\"button\");\n      btn.className = \"slot\" + (who?\" taken\":\"\") + (slot===selected?\" sel\":\"\");\n      btn.textContent = fmtShort(slot);\n      btn.title = who ? `Taken by ${who}` : fmt(slot);\n      btn.disabled = !!who;\n      if (!who) btn.onclick = () => {\n        selected = selected===slot ? null : slot;\n        updateSubmitBtn();\n        buildGrid();\n        const tag = $(\"selected-tag\");\n        if (selected) { tag.textContent = `\u2014 ${fmt(selected)} selected`; tag.classList.remove(\"hidden\"); }\n        else tag.classList.add(\"hidden\");\n      };\n      grid.appendChild(btn);\n    });\n  }\n\n  function updateSubmitBtn() {\n    const btn = $(\"submit-btn\");\n    btn.textContent = selected ? `\ud83d\udd12 Lock in ${fmt(selected)}` : \"Lock in my pick\";\n  }\n\n  function renderBoard() {\n    const sorted = [...picks].sort((a,b)=>a.time.localeCompare(b.time));\n    $(\"board-count\").textContent = `(${picks.length} / ${SLOTS.length})`;\n    const list = $(\"pick-list\");\n    if (sorted.length===0) {\n      list.innerHTML = `<div class=\"empty\"><div class=\"empty-icon\">\ud83d\udd50</div><p>No picks yet \u2014 be the first!</p></div>`;\n      return;\n    }\n    list.innerHTML = sorted.map((p,i)=>`\n      <div class=\"pick-row\">\n        <span class=\"pick-num\">#${i+1}</span>\n        <span class=\"pick-time\">${fmt(p.time)}</span>\n        <span class=\"pick-name\">${p.name.replace(/</g,\"&lt;\")}</span>\n      </div>`).join(\"\");\n  }\n\n  function updateBanners() {\n    const status = getBettingStatus();\n    const mi = getMtInfo();\n    const minsLeft = 12*60-(mi.hour*60+mi.minute);\n    const ct = minsLeft>=60?`${Math.floor(minsLeft/60)}h ${minsLeft%60}m`:`${minsLeft}m`;\n\n    $(\"banner-closed\").classList.toggle(\"hidden\", status!==\"closed\");\n    $(\"banner-waiting\").classList.toggle(\"hidden\", status!==\"waiting\");\n    $(\"banner-open\").classList.toggle(\"hidden\", status!==\"open\");\n\n    if (status===\"closed\") $(\"next-wed-label\").textContent = `Next Snack Bet opens ${getNextWednesdayLabel()}`;\n    if (status===\"waiting\") $(\"countdown-text\").textContent = `${ct} to go`;\n    if (status===\"open\") $(\"slots-left\").textContent = `${SLOTS.length-picks.length} slot${SLOTS.length-picks.length!==1?\"s\":\"\"} left`;\n\n    const isLocked = status!==\"open\" || !!myVote;\n    $(\"form-card\").classList.toggle(\"locked\", isLocked);\n    $(\"submit-btn\").classList.toggle(\"hidden\", isLocked);\n\n    // Already voted banner\n    if (myVote && status===\"open\") {\n      $(\"banner-voted\").classList.remove(\"hidden\");\n      $(\"voted-title\").textContent = `\ud83d\udd12 You're locked in at ${fmt(myVote.time)}`;\n      $(\"voted-sub\").textContent = `Good luck, ${myVote.name}!`;\n    } else {\n      $(\"banner-voted\").classList.add(\"hidden\");\n    }\n  }\n\n  async function loadPicks() {\n    try {\n      const all = await readPicks();\n      picks = all.filter(p=>p.week===weekKey);\n      myVote = getMyVote(weekKey);\n      buildGrid();\n      renderBoard();\n      updateBanners();\n    } catch(e) {\n      showError(`Couldn't load picks: ${e.message}`);\n    }\n  }\n\n  $(\"submit-btn\").onclick = async () => {\n    hideError();\n    const name = $(\"name-input\").value.trim();\n    if (!name) { showError(\"Enter your name first.\"); return; }\n    if (!selected) { showError(\"Select a time slot.\"); return; }\n    if (getBettingStatus() !== \"open\") {\n      showError(\"Betting isn't open right now \u2014 refresh the page to see current status.\");\n      updateBanners();\n      return;\n    }\n    $(\"submit-btn\").disabled = true;\n    $(\"submit-btn\").textContent = \"Locking in\u2026\";\n    try {\n      const all = await readPicks();\n      const weekly = all.filter(p=>p.week===weekKey);\n      if (weekly.find(p=>p.time===selected)) {\n        showError(`${fmt(selected)} was just taken \u2014 pick another!`);\n        picks = weekly; selected = null; buildGrid(); renderBoard(); updateBanners();\n        $(\"submit-btn\").disabled = false; updateSubmitBtn(); return;\n      }\n      if (weekly.find(p=>p.name.toLowerCase()===name.toLowerCase())) {\n        showError(`\"${name}\" already has a pick this week.`);\n        $(\"submit-btn\").disabled = false; updateSubmitBtn(); return;\n      }\n      const newPick = { id: Date.now(), name, time: selected, week: weekKey };\n      await writePicks([...all, newPick]);\n      const vote = { name, time: selected };\n      setMyVote(weekKey, vote);\n      myVote = vote;\n      picks = [...weekly, newPick];\n      selected = null;\n      $(\"name-input\").value = \"\";\n      $(\"selected-tag\").classList.add(\"hidden\");\n      showSuccess(`${name} locked in ${fmt(vote.time)}! \ud83d\udd12`);\n      buildGrid(); renderBoard(); updateBanners();\n    } catch(e) {\n      showError(`Save failed: ${e.message}`);\n      $(\"submit-btn\").disabled = false; updateSubmitBtn();\n    }\n  };\n\n  $(\"name-input\").addEventListener(\"keydown\", e => e.key===\"Enter\" && $(\"submit-btn\").click());\n\n  // Init\n  myVote = getMyVote(weekKey);\n  updateBanners();\n  loadPicks();\n  setInterval(loadPicks, 10000);\n  setInterval(updateBanners, 30000);\n\n  // Browsers pause/throttle timers in background tabs \u2014 force a re-check\n  // the instant someone returns to this tab or the window regains focus,\n  // so a stale \"unlocked\" view can't linger past the actual lock time.\n  document.addEventListener(\"visibilitychange\", () => {\n    if (!document.hidden) { updateBanners(); loadPicks(); }\n  });\n  window.addEventListener(\"focus\", () => { updateBanners(); loadPicks(); });\n\n</script>\n</body>\n</html>\n"
}